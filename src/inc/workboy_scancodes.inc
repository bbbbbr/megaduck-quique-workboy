

; WORKBOY_SYS_KEY_*  : Translated keys after conversion for system use
; WORKBOY_SCAN_KEY_* : Codes received from hardware (or Megaduck compat layer)


; Workboy[NUM KEY] -> is the shift key?
; But it always selects the alternate superscript key?
;

; CAPS and NUM keys toggle which set of keycodes is used
; 
; WORKBOY_SCAN_KEY_SHIFT_DOWN (0x27) -> NUM Key  (0x0B in translated key format) Pressed
; WORKBOY_SCAN_KEY_SHIFT_UP   (0x32) -> CAPS Key (0x0C in translated key format) Pressed


; Commented out means not yet assigned in
; megaduck_to_workboy_keyboard_keycode_recode_table_spanish


DEF WORKBOY_SCAN_KEY_EMPTY_MAYBE       EQU $00
DEF WORKBOY_SCAN_KEY_NONE              EQU $FF
;DEF WORKBOY_SCAN_KEY_REQUIRE_SHIFT    EQU $40
;DEF WORKBOY_SCAN_KEY_BLOCK_SHIFT      EQU $80

; IO_MOCK_SHIFT allows some keys which require shift
; to be sent as a sequence of SHIFT DOWN -> KEY -> SHIFT UP
; in the Duck -> Workboy compatibility layer
; See:
; - DUCK_WORKBOY_SHIFT_WRAP_SEND_SHIFT_DOWN
; - send_shift_released_key_and_state_to_reset
DEF WORKBOY_IO_MOCK_SHIFT              EQU $80
DEF WORKBOY_IO_MOCK_SHIFT_BIT          EQU 7

    
